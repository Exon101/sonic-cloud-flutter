# ─────────────────────────────────────────────────────────────────────────────
# Sonic Cloud — environment variable template.
#
# Copy to `.env` and fill in real values. Never commit the real `.env`.
#
#   cp .env.example .env
#
# All scripts in `scripts/` and all CI workflows read these from the
# environment. For CI, set them as repository secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Android signing ──────────────────────────────────────────────────────────
# Path to the release keystore (.jks). On CI this is reconstructed from
# ANDROID_KEYSTORE_BASE64.
ANDROID_KEYSTORE_PATH=./android/app/keystore.jks
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=
# Base64-encoded keystore (used by GitHub Actions / Codemagic to reconstruct the file):
ANDROID_KEYSTORE_BASE64=

# ── Google Play Store ────────────────────────────────────────────────────────
# Path to a service-account JSON file with Play Store permissions.
PLAY_STORE_JSON_KEY=

# ── Apple ────────────────────────────────────────────────────────────────────
APPLE_ID=you@example.com
TEAM_ID=
# App-specific password (account → sign-in & security → app-specific passwords):
APPLE_APP_SPECIFIC_PASSWORD=

# ── Fastlane match (iOS signing certs) ───────────────────────────────────────
MATCH_GIT_URL=
MATCH_PASSWORD=

# ── Firebase App Distribution ────────────────────────────────────────────────
# Get with: `firebase apps:list` or in the Firebase console.
FIREBASE_APP_ID_ANDROID=
FIREBASE_APP_ID_IOS=
# Get with: `firebase login:ci`
FIREBASE_TOKEN=
# Firebase project ID (for Hosting deploys):
FIREBASE_PROJECT_ID=sonic-cloud-app

# ── Codecov (optional) ───────────────────────────────────────────────────────
CODECOV_TOKEN=
